{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceFile",
    "programme",
    "handbookYear",
    "title",
    "totalUnits",
    "categories",
    "evidence",
    "confidence",
    "ambiguities"
  ],
  "properties": {
    "sourceFile": { "type": "string" },
    "programme": { "type": "string" },
    "handbookYear": { "type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}$" },
    "title": { "type": "string", "minLength": 1 },
    "totalUnits": { "type": "integer", "minimum": 1, "maximum": 200 },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/category" }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "totalUnits"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "totalUnits": { "type": "string", "minLength": 1 }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "ambiguities": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "members", "textualRule", "evidence"],
      "properties": {
        "name": { "type": "string" },
        "members": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{3,4}[0-9]{4}$" }
        },
        "textualRule": { "type": ["string", "null"] },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "unitsRequired",
        "pickN",
        "members",
        "textualRule",
        "groups",
        "constraints",
        "evidence"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["required", "one-of", "basket"] },
        "unitsRequired": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 200
        },
        "pickN": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "members": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{3,4}[0-9]{4}$" }
        },
        "textualRule": { "type": ["string", "null"] },
        "groups": { "type": "array", "items": { "$ref": "#/$defs/group" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "string", "minLength": 1 }
      }
    }
  }
}
