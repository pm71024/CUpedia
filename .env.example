# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cuclaw

# Auth
AUTH_SECRET=dev-secret-change-in-production
AUTH_URL=http://localhost:3000

# Brevo email delivery
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@cupedia.org

# Dev-only: bypass @cuhk.edu.hk email whitelist
SKIP_EMAIL_WHITELIST=true

# Dev-only: canteen in-memory data (no PostgreSQL required for P0 preview)
# CANTEEN_MOCK_DATA=true

# Canteen voting (anonymous session + rate limits)
# CANTEEN_ANON_SESSION_TTL_SECONDS=3600
# CANTEEN_VOTE_RATE_LIMIT_PER_MIN=60

# Canteen OCR menu import (Admin-only; mock when unset)
# GOOGLE_CLOUD_VISION_API_KEY=your-google-vision-api-key
# CANTEEN_OCR_MOCK=true
# CANTEEN_OCR_RATE_LIMIT_PER_HOUR=20

# Homepage danmaku: max posts per user per hour (default 5)
DANMAKU_RATE_LIMIT_PER_HOUR=5

# Sensitive-word filter on comment / danmaku publish (default: on)
# SENSITIVE_CONTENT_FILTER=false

# Storage (S3-compatible: MinIO / Cloudflare R2 / AWS S3)
# MinIO:  MINIO_ENDPOINT=localhost  MINIO_PORT=9000
# R2/S3:  MINIO_ENDPOINT=https://<account>.r2.cloudflarestorage.com  (omit MINIO_PORT)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cuclaw-uploads
MINIO_PUBLIC_URL=http://localhost:9000/cuclaw-uploads
