# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cuclaw

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=noreply@cuclaw.app

# Storage (S3-compatible: MinIO / Cloudflare R2 / AWS S3)
# MinIO:  MINIO_ENDPOINT=localhost  MINIO_PORT=9000
# R2/S3:  MINIO_ENDPOINT=https://<account>.r2.cloudflarestorage.com  (omit MINIO_PORT)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cuclaw-uploads
MINIO_PUBLIC_URL=http://localhost:9000/cuclaw-uploads
